{
  "name": "forgemoment",
  "version": "0.0.2",
  "description": "Shared React component library for the lqr studio family — primitives, charts/timeline, MediaViewer (master clock), HoldSeekButton, TransformPanel, AppShell.",
  "type": "module",
  "main": "./dist/forgemoment.cjs.js",
